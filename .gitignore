# ============================================
#  Lumira — Root .gitignore
# ============================================

# ---------- Environment & Secrets ----------
.env
.env.*
!.env.example

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
env/

# ---------- Databases ----------
*.db
*.db-shm
*.db-wal
*.sqlite3

# ---------- ChromaDB / Vector Store ----------
backend/chroma_db/
backend/Database/

# ---------- User-Uploaded Data (runtime) ----------
backend/Dataset/

# ---------- Node / Frontend ----------
node_modules/
dist/
dist-ssr/
*.local

# ---------- IDE ----------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- OS ----------
Thumbs.db
Desktop.ini
.DS_Store

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Misc ----------
*.bak
*.tmp
